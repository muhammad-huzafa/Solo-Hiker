// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum HikingLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum JoinStatus {
  PENDING
  APPROVED
  REJECTED
}

enum TripDifficulty {
  EASY
  MODERATE
  HARD
  EXPERT
}

model User {
  id            String      @id @default(auto()) @map("_id") @db.ObjectId
  email         String      @unique
  name          String?
  password      String
  age           Int
  cnic          String?
  hikingLevel   HikingLevel @default(BEGINNER)
  emailVerified Boolean     @default(false)
  isAdmin   Boolean  @default(false)   
  trips         Trip[]
  joinRequests  JoinRequest[] @relation("UserJoinRequests")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model JoinRequest {
  id String @id @default(auto()) @map("_id") @db.ObjectId

  userId String @db.ObjectId
  tripId String @db.ObjectId

  status JoinStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation("UserJoinRequests", fields: [userId], references: [id], onDelete: Cascade)
  trip Trip @relation("TripJoinRequests", fields: [tripId], references: [id], onDelete: Cascade)

  @@unique([userId, tripId])
  @@index([userId])
  @@index([tripId])
}
model Trip {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  title       String
  description String
  location    String

  startDate DateTime
  endDate   DateTime

  difficulty          TripDifficulty @default(EASY)
  maxParticipants     Int
  currentParticipants Int            @default(1)

  images String[] // Array of Cloudinary URLs

  isPublic Boolean @default(true)

  userId String @db.ObjectId
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  participants String[]  @db.ObjectId
  joinRequests JoinRequest[] @relation("TripJoinRequests")
}
// ─────────────────────────────────────────────
// CHAT FEATURE — Naye Models
// Existing models ko bilkul touch mat karo
// ─────────────────────────────────────────────

model Conversation {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  // ↑ MongoDB ka default ObjectId

  participants String[] @db.ObjectId
  // ↑ Array of User IDs jo is conversation mein hain
  // ↑ Example: ["64abc...", "64def..."]
  // ↑ @db.ObjectId: yeh MongoDB ObjectId hain

  lastMessage     String?  @default("")
  // ↑ Conversation list mein preview ke liye
  // ↑ ? = optional — pehle koi message nahi hota

  lastMessageTime DateTime @default(now())
  // ↑ Sorting ke liye — latest conversation upar dikhe

  messages Message[]
  // ↑ Is conversation ke saare messages (relation)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Message {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId

  conversationId String   @db.ObjectId
  // ↑ Kaunsi conversation mein hai yeh message
  // ↑ Conversation model se linked hai

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  // ↑ Agar conversation delete ho → saare messages bhi delete
  // ↑ fields: [conversationId] → yeh field use karo
  // ↑ references: [id] → Conversation ka id se match karo

  senderId   String @db.ObjectId
  // ↑ Kisne bheja — User ka _id
  // ↑ Note: Direct relation nahi banaya kyunke
  //   WebSocket mein hum string ID use karte hain

  senderName String
  // ↑ User ka naam — denormalization
  // ↑ Matlab: User delete ho jaaye phir bhi naam dikhega

  text String
  // ↑ Message ka content

  isRead Boolean  @default(false)
  // ↑ Padha ya nahi — read receipt ke liye

  readAt DateTime?
  // ↑ Kab padha — null agar abhi tak nahi padha
  // ↑ ? = optional

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([conversationId])
  // ↑ Index: conversationId pe search fast hogi
  // ↑ Jab conversation ke messages load karein ge toh fast aayenge
}